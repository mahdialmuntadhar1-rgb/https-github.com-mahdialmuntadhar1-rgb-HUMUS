VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# CRM Messaging System (Supabase Secrets - not frontend env vars)
# These are set via: supabase secrets set KEY=value
# SUPABASE_SERVICE_ROLE_KEY=

# WhatsApp Cloud API (for bulk sender)
# WHATSAPP_API_TOKEN=your_whatsapp_api_token
# WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id

# Bulk Sender Config (optional)
# BULK_SEND_DELAY_MS=3000  # Delay between messages (default: 3000ms = 20 msg/min)
