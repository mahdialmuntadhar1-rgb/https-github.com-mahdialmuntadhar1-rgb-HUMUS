# ─────────────────────────────────────────────
# BELIVE — Environment Variables
# Copy this file to .env.local (Vite) or set in Vercel dashboard
# ─────────────────────────────────────────────

# ── Supabase (REQUIRED) ────────────────────────
# Get these from: https://supabase.com/dashboard/project/hsadukhmcclwixuntqwu/settings/api
VITE_SUPABASE_URL=https://hsadukhmcclwixuntqwu.supabase.co
VITE_SUPABASE_ANON_KEY=

# The ANON key is safe for client-side use — it is scoped by RLS.
# NEVER put the service_role key here.

# ── Google OAuth (OPTIONAL) ────────────────────
# Only needed if you want Google login to work.
# Configure in: Supabase Dashboard → Auth → Providers → Google
# Then add your domain to the Google OAuth redirect allowlist.
# If not configured, the Google login button will show an error gracefully.
VITE_GOOGLE_CLIENT_ID=

# ── App Config (OPTIONAL) ──────────────────────
# Used for OAuth redirect and PWA manifest
VITE_APP_URL=http://localhost:3000

# ── Dev Notes ──────────────────────────────────
# The app has hardcoded fallback credentials for immediate local testing.
# Set these vars for production to avoid exposing credentials in source code.
# See supabase/README.md for full backend setup guide.
